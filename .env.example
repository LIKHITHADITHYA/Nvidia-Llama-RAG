# Environment configurations for Nvidia-Llama-RAG project
# Duplicate this file, rename it to .env, and fill in your actual API keys.

# NVIDIA API Key for Large Language Model access
# Obtain at: https://build.nvidia.com/
NVIDIA_API_KEY="your-nvidia-api-key-here"

# SerpAPI Key for Real-Time Search capabilities
# Obtain at: https://serpapi.com/
SERPAPI_API_KEY="your-serpapi-api-key-here"
